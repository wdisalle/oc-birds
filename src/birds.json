{
  "_readme": {
    "about": "Bird image repository for OC Hikes & Birds app.",
    "how_to_add_photos": [
      "1. Go to https://search.macaulaylibrary.org/catalog?taxonCode=BIRD_CODE&mediaType=Photo",
      "2. Search by common name, filter to Photo, sort by Rating",
      "3. Click a photo you like, copy the asset number from the URL (e.g. ML123456789)",
      "4. Build the URL: https://cdn.download.ams.birds.cornell.edu/api/v2/asset/ML_NUMBER/1200",
      "5. Add it to the photos array below with an appropriate label",
      "",
      "Label conventions: Adult Male, Adult Female, Juvenile, Immature, Breeding Adult, Non-breeding Adult, In Flight",
      "",
      "iNaturalist photos: https://www.inaturalist.org/taxa/search?q=BIRD+NAME",
      "  Click the taxon, then 'View photos' — right-click any photo, copy image address",
      "  Or use S3 format: https://inaturalist-open-data.s3.amazonaws.com/photos/PHOTO_ID/medium.jpg",
      "",
      "Your own photos: add to /public/bird-photos/FILENAME.jpg and reference as /bird-photos/FILENAME.jpg"
    ],
    "macaulay_library_url_format": "https://cdn.download.ams.birds.cornell.edu/api/v2/asset/{ML_NUMBER}/1200",
    "inaturalist_url_format": "https://inaturalist-open-data.s3.amazonaws.com/photos/{PHOTO_ID}/medium.jpg"
  },

